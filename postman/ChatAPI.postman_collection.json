{
    "info": {
        "name": "ChatAPP (Slack-Lite) API v1",
        "_postman_id": "a1b2c3d4-e5f6v1-1d2f3b4c5d6e",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
        "description": "A minimal blueprint for a Postman API collection"
    },
    "variables": [
        {
            "key": "base_url",
            "value": "http://localhost:5000/api/v1",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "☮️ Health",
            "item": [
                {
                    "name": "Health check",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/health"
                    }
                }
            ]
        },
        {
            "name": "🔐 Auth",
            "item": [
                {
                    "name": "Register",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if(pm.response.code === 201){ pm.collectionVariables.set('token', pm.response.json().data.token); }"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"demo@example.com\",\n  \"username\": \"demouser\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if(pm.response.code === 200){ pm.collectionVariables.set('token', pm.response.json().data.token); }"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Get Current User (Me)",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/auth/me",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ]
                    }
                }
            ]
        }
    ]
}